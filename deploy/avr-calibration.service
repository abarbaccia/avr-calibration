[Unit]
Description=AVR Calibration — web server
After=network.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__INSTALL_DIR__
ExecStart=__INSTALL_DIR__/.venv/bin/python -m uvicorn calibrate.web:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
Environment=PATH=__INSTALL_DIR__/.venv/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
